{
  "manifest_version": 3,
  "name": "HappyWeather",
  "version": "4.2",
  "action": {
    "default_popup": "popup.html"
  },
    "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://wttr.in/*"],
  "browser_specific_settings": {
    "gecko": { "id": "happyweather@ijahangard.github.com" }
  }
}